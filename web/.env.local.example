SQL_CONNECTION_STRING=Server=tcp:<server>.database.windows.net,1433;Database=<db>;User ID=<user>;Password=<pass>;Encrypt=true;TrustServerCertificate=false;Connection Timeout=30;
## Optional (recommended in production). If set, ESP32 must send matching x-api-key on /api/qr/scan.
# API_KEY=change-me

## Optional (recommended). If set, belt ESP32 must send matching x-belt-secret on POST /api/belt/events.
# BELT_EVENTS_SECRET=change-me

## Optional conveyor "Category A" slide: when decoded QR text contains this substring (case-insensitive),
## Next.js POSTs JSON to your device/PLC HTTP endpoint (fire-and-forget, does not block the scan response).
# CONVEYOR_SLIDE_WEBHOOK_URL=http://<conveyor-host>/slide
# CONVEYOR_SLIDE_TRIGGER_SUBSTRING=Category A
# CONVEYOR_SLIDE_WEBHOOK_SECRET=shared-secret-for-your-microcontroller
